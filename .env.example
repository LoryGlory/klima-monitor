# Poll interval (cron expression). Default: every 3 minutes.
CRON=*/3 * * * *

# Up to ±N seconds of random jitter added before each target fetch (politeness).
JITTER_SECONDS=20

# --- Notifications: set ONE of the two ---

# Telegram (recommended: instant, free). Create a bot via @BotFather, then send it a
# message and read your chat id from https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ntfy.sh (no account needed; pick an unguessable topic name)
NTFY_TOPIC=

# Contact line included in the User-Agent so retailers can reach you if needed.
CONTACT_EMAIL=you@example.com

# Suppress Telegram alerts for any InStock listing priced strictly above this
# (in €). Useful for ignoring overpriced marketplace listings. Items with no
# detected price still fire. Leave unset = no cap.
MAX_PRICE_EUR=
